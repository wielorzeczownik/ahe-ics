{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "platformAutomerge": true,
  "automergeType": "pr",
  "semanticCommits": "enabled",
  "minimumReleaseAge": "3 days",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^README(\\.pl)?\\.md$"
      ],
      "matchStrings": [
        "python:(?<currentValue>[^\\s\"']+)"
      ],
      "depNameTemplate": "python",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Dockerfile(\\.alpine)?$"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[\\w.]+?) depName=(?<depName>[\\w.\\/-]+?)(?: versioning=(?<versioning>[\\w]+?))?\\nARG \\w+=\"(?<currentValue>[^\"]+)\""
      ]
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": [
        "buildDependencies"
      ],
      "semanticCommitType": "build"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "minimumReleaseAge": "7 days",
      "semanticCommitType": "ci"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "pinDigests": true,
      "semanticCommitType": "build"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "pinDigests": true,
      "matchPackageNames": [
        "debian"
      ],
      "semanticCommitType": "chore"
    },
    {
      "matchManagers": [
        "regex"
      ],
      "matchFileNames": [
        "README.md",
        "README.pl.md"
      ],
      "semanticCommitType": "docs"
    },
    {
      "matchManagers": [
        "regex"
      ],
      "matchFileNames": [
        "Dockerfile"
      ],
      "semanticCommitType": "build",
      "groupName": "debian packages"
    },
    {
      "matchManagers": [
        "regex"
      ],
      "matchFileNames": [
        "Dockerfile.alpine"
      ],
      "semanticCommitType": "build",
      "groupName": "alpine packages"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "docker/build-push-action",
        "docker/login-action",
        "docker/metadata-action",
        "docker/setup-buildx-action",
        "docker/setup-qemu-action"
      ],
      "groupName": "docker actions"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "actions/upload-artifact",
        "actions/download-artifact"
      ],
      "groupName": "artifact actions"
    }
  ]
}
