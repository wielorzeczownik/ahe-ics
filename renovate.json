{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "platformAutomerge": true,
  "automergeType": "pr",
  "semanticCommits": "enabled",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^README(\\.pl)?\\.md$"],
      "matchStrings": ["python:(?<currentValue>[^\\s\"']+)"],
      "depNameTemplate": "python",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": [
        "buildDependencies"
      ],
      "semanticCommitType": "build"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitType": "ci"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "semanticCommitType": "build"
    },
    {
      "matchManagers": [
        "regex"
      ],
      "semanticCommitType": "docs"
    }
  ]
}
